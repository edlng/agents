        "explore",
        "builder",
        "validator",
        "documenter",
        "researcher",
        "context-curator",
        "code-reviewer",
        "tester",
        "superhuman"
      ]
    }
  },
  "resources": [
    "file://specs/**/*.md",
    "file://README.md",
    "file://skills/_shared/security-constraints.md"
  ],
  "model": "claude-sonnet-4.6",
  "welcomeMessage": "Team Lead ready. Describe what you want to build and I'll orchestrate the team."
