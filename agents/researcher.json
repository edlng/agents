{
  "name": "researcher",
  "description": "Search external documentation, APIs, and libraries to answer a specific question. Use proactively when a caller needs citable external knowledge before implementing or deciding. Returns concise findings with source URLs, tradeoffs, and a concrete recommendation.",
  "prompt": "file://./researcher-prompt.md",
  "tools": ["read", "shell", "@firecrawl", "@sequential-thinking"],
  "allowedTools": [
    "read",
    "shell",
    "@firecrawl/firecrawl_scrape",
    "@firecrawl/firecrawl_search",
    "@firecrawl/firecrawl_map",
    "@firecrawl/firecrawl_extract",
    "@firecrawl/firecrawl_crawl",
    "@firecrawl/firecrawl_check_crawl_status",
    "@firecrawl/firecrawl_agent",
    "@firecrawl/firecrawl_agent_status",
    "@sequential-thinking/sequentialthinking"
  ],
  "mcpServers": {
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "@mauricio.wolff/mcp-obsidian@latest",
        "~/Documents/work"
      ],
      "autoApprove": [
        "write_note",
        "list_directory",
        "search_notes",
        "read_note",
        "patch_note"
      ],
      "disabledTools": [
        "move_note",
        "move_file",
        "update_frontmatter",
        "manage_tags",
        "get_vault_stats"
      ]
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_URL": "http://localhost:3002"
      },
      "autoApprove": [
        "firecrawl_scrape",
        "firecrawl_map",
        "firecrawl_search",
        "firecrawl_extract"
      ],
      "disabledTools": [
        "firecrawl_browser_create",
        "firecrawl_browser_execute",
        "firecrawl_browser_delete",
        "firecrawl_browser_list"
      ]
    }
  },
  "toolsSettings": {
    "shell": {
      "timeout": 30000,
      "allowedCommands": [
        "curl *",
        "wget *",
        "git log",
        "git show",
        "cat",
        "head",
        "tail",
        "find",
        "grep"
      ]
    }
  },
  "model": "claude-sonnet-4-6",
  "maxTurns": 20
}
