{
  "name": "context-curator",
  "description": "Curates memory context for worker agents. Given a task description, selects relevant memories from Valkey and Obsidian and returns a <context-memory> block. Does NOT perform tasks.",
  "prompt": "file://./context-curator-prompt.md",
  "tools": [
    "read",
    "shell",
    "@obsidian"
  ],
  "allowedTools": [
    "read",
    "shell",
    "@obsidian/search_notes",
    "@obsidian/read_note",
    "@obsidian/list_directory"
  ],
  "mcpServers": {
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "@mauricio.wolff/mcp-obsidian@latest",
        "~/Documents/work"
      ],
      "autoApprove": [
        "search_notes",
        "read_note",
        "list_directory"
      ],
      "disabledTools": [
        "write_note",
        "patch_note",
        "move_note",
        "move_file",
        "update_frontmatter",
        "manage_tags",
        "get_vault_stats"
      ]
    }
  },
  "model": "claude-haiku-4.5",
  "resources": [
    "file://skills/_shared/security-constraints.md"
  ]
}