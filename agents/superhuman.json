{
  "name": "superhuman",
  "description": "Expert engineer with deep domain knowledge in AWS, backend, UI/UX, and architecture. Use proactively for complex, multi-step engineering tasks requiring deep reasoning. Uses sequential thinking for complex problem-solving and firecrawl for research. Cross-checks all solutions for correctness.",
  "mcpServers": {
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_URL": "${FIRECRAWL_API_URL:-http://localhost:3002}"
      },
      "autoApprove": [
        "firecrawl_scrape",
        "firecrawl_map",
        "firecrawl_search",
        "firecrawl_extract"
      ],
      "disabledTools": [
        "firecrawl_browser_create",
        "firecrawl_browser_execute",
        "firecrawl_browser_delete",
        "firecrawl_browser_list"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  },
  "tools": [
    "read",
    "write",
    "shell",
    "glob",
    "grep",
    "code",
    "todo_list",
    "use_aws",
    "web_fetch",
    "web_search",
    "@firecrawl",
    "@sequential-thinking"
  ],
  "allowedTools": [
    "read",
    "write",
    "shell",
    "glob",
    "grep",
    "code",
    "todo_list",
    "use_aws",
    "web_fetch",
    "web_search",
    "@firecrawl/firecrawl_scrape",
    "@firecrawl/firecrawl_search",
    "@firecrawl/firecrawl_map",
    "@firecrawl/firecrawl_extract",
    "@firecrawl/firecrawl_crawl",
    "@firecrawl/firecrawl_check_crawl_status",
    "@firecrawl/firecrawl_agent",
    "@firecrawl/firecrawl_agent_status",
    "@sequential-thinking/sequentialthinking"
  ],
  "prompt": "file://./superhuman-prompt.md",
  "model": "claude-opus-4.8",
  "resources": [
    "file://skills/_shared/security-constraints.md"
  ],
  "useLegacyMcpJson": false
}